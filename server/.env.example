PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart-hostel
MONGO_DB_NAME=smart-hostel
JWT_SECRET=your_super_secret_jwt_key_min_16_chars

# CORS — exact browser origin of your frontend (no trailing slash)
CLIENT_URL=http://localhost:5173
# Production examples:
# CLIENT_URL=https://my-hostel-client.vercel.app
# CLIENT_URLS=https://your-preview.vercel.app

NODE_ENV=development

MOCK_OTP=true
MOCK_PAYMENTS=true
