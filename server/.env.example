PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart-hostel
MONGO_DB_NAME=smart-hostel

# ⚠️ IMPORTANT: Change this to a LONG, UNIQUE, random string for production.
# Do NOT use the placeholder value below in production — it's insecure.
JWT_SECRET=your_super_secret_jwt_key_min_16_chars

# Strongly recommended: set a separate REFRESH_TOKEN_SECRET.
# If not set, falls back to JWT_SECRET (less secure).
# REFRESH_TOKEN_SECRET=another_long_random_string

# CORS — exact browser origin of your frontend (no trailing slash).
# Set this to your production frontend URL before deploying.
CLIENT_URL=http://localhost:5173
# Production examples:
# CLIENT_URL=https://my-hostel-client.vercel.app
# CLIENT_URLS=https://your-preview.vercel.app

NODE_ENV=development

# Mock mode enables OTP bypass (123456) and mock payments — DISABLE in production.
MOCK_OTP=true
MOCK_PAYMENTS=true

# Razorpay Payment Gateway — required for online payments:
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# ── Email (SMTP) — Required for OTP delivery ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password  (Generate from Google > App Passwords)
# EMAIL_FROM="Sri Rama Hostel <noreply@gmail.com>"
# SEND_REAL_EMAIL=false  (Set "true" to actually send emails; when false, OTPs are logged to console)
