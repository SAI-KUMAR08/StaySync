# Copy to .env.development (local) or set in Vercel/Netlify (production)
# --- Production build (Vercel) ---
# VITE_API_URL=https://myhostel-server.onrender.com
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxx

# --- Local dev (npm run dev) — leave VITE_API_URL unset ---
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000
# VITE_DEV_PROXY_TARGET=https://myhostel-server.onrender.com

