{
  "name": "stay-sync",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:api": "npm run dev --prefix server",
    "dev:web": "npm run dev --prefix client",
    "install:all": "npm install --prefix server && npm install --prefix client",
    "build": "cd client && npx vite build",
    "start": "node src/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
